# ──────────────────────────────────────────
# AI PROVIDER
# ──────────────────────────────────────────
# Which LLM to use: "gemini" (production) or "groq" (development, free + fast).
# Default: gemini
AI_PROVIDER=gemini

# ──────────────────────────────────────────
# GEMINI AI (Google AI Studio - free tier)
# Get your key at: https://aistudio.google.com/app/apikey
# Required when AI_PROVIDER=gemini
# ──────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: override the model. Default: gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# ──────────────────────────────────────────
# GROQ AI (alternative provider for development)
# Get your key at: https://console.groq.com/keys
# Required when AI_PROVIDER=groq
# ──────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
# Optional: override the model. Default: llama-3.3-70b-versatile
# See https://console.groq.com/docs/models for available models.
# GROQ_MODEL=llama-3.3-70b-versatile

# ──────────────────────────────────────────
# GOOGLE CALENDAR
# ──────────────────────────────────────────
# Your Google Calendar ID (usually your Gmail address or a dedicated calendar ID)
GOOGLE_CALENDAR_ID=your_calendar_id@gmail.com

# Path to the downloaded service account JSON key file
GOOGLE_SERVICE_ACCOUNT_PATH=./credentials/google-service-account.json

# ──────────────────────────────────────────
# BOT SETTINGS
# ──────────────────────────────────────────
PORT=3008

# Timezone for appointments (IANA format)
# Examples: America/Bogota | America/Mexico_City | America/Lima | America/Santiago
TIMEZONE=America/Bogota
