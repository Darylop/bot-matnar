# ──────────────────────────────────────────
# AI PROVIDER
# ──────────────────────────────────────────
# Which LLM to use: "gemini" (production) or "groq" (development, free + fast).
# Default: gemini
AI_PROVIDER=gemini

# ──────────────────────────────────────────
# GEMINI AI (Google AI Studio - free tier)
# Get your key at: https://aistudio.google.com/app/apikey
# Required when AI_PROVIDER=gemini
# ──────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: override the model. Default: gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# ──────────────────────────────────────────
# GROQ AI (alternative provider for development)
# Get your key at: https://console.groq.com/keys
# Required when AI_PROVIDER=groq
# ──────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
# Optional: override the model. Default: llama-3.3-70b-versatile
# See https://console.groq.com/docs/models for available models.
# GROQ_MODEL=llama-3.3-70b-versatile

# ──────────────────────────────────────────
# GOOGLE CALENDAR
# ──────────────────────────────────────────
# Your Google Calendar ID. With OAuth use 'primary' (or the email of the owner).
GOOGLE_CALENDAR_ID=primary

# ── OPTION A (RECOMMENDED for personal Gmail): OAuth 2.0 with refresh token
# Allows the bot to:
#   - add the client as `attendee` and send the invitation email automatically
#   - generate the Google Meet link inside the event
#
# How to obtain these values (one-time setup):
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create an OAuth 2.0 Client ID of type "Web application"
#      Authorized redirect URI: https://developers.google.com/oauthplayground
#   3. Open https://developers.google.com/oauthplayground
#      Click the gear icon ⚙ → "Use your own OAuth credentials" → paste Client ID and Secret
#      In the scopes list, paste: https://www.googleapis.com/auth/calendar
#      Click "Authorize APIs", sign in WITH THE CALENDAR OWNER'S ACCOUNT, accept.
#      Click "Exchange authorization code for tokens" → copy the `refresh_token`
#   4. Fill the three variables below and remove (or keep) the service account fallback.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# ── OPTION B (FALLBACK): Service Account (cannot invite attendees nor create Meet
# on personal Gmail; only works fully on Google Workspace with Domain-Wide Delegation)
GOOGLE_SERVICE_ACCOUNT_PATH=./credentials/google-service-account.json

# ──────────────────────────────────────────
# BOT SETTINGS
# ──────────────────────────────────────────
PORT=3008

# Timezone for appointments (IANA format)
# Examples: America/Bogota | America/Mexico_City | America/Lima | America/Santiago
TIMEZONE=America/Bogota
